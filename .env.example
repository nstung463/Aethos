AETHOS_MANAGED_FILES_DIR=./workspace/managed_files

# LLM Provider Configuration
AETHOS_PROVIDER=openrouter
AETHOS_MODEL=openai/gpt-4o-mini

# API Keys (choose one provider)
# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxx

# Or Anthropic
# ANTHROPIC_API_KEY=sk-ant-xxx

# Or OpenAI
# OPENAI_API_KEY=sk-xxx

# Optional: Multiple Models Registry (JSON array)
# AETHOS_MODEL_REGISTRY=[{"id":"aethos","provider":"openrouter","model":"openai/gpt-4o-mini"}]
AETHOS_PUBLIC_BASE_URL=http://127.0.0.1:8080
AETHOS_SECRETS_KEY=some-long-random-secret
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Local PostgreSQL auth storage
AETHOS_DATABASE_ENABLED=true
AETHOS_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/aethos
AETHOS_DATABASE_AUTO_MIGRATE=true
AETHOS_AUTH_REPOSITORY_BACKEND=postgres
# AETHOS_REDIS_URL=redis://localhost:6379/0
# AETHOS_OBJECT_STORAGE_BUCKET=aethos-dev
# AETHOS_OBJECT_STORAGE_ENDPOINT=http://localhost:9000
# AETHOS_OBJECT_STORAGE_REGION=us-east-1
